# ================================================================
# Loocbooc Environment Variables
# Copy this to .env and fill in your values
# ================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://loocbooc:loocbooc@postgres:5432/loocbooc

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Storage (MinIO for dev — no AWS credentials needed) ---
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=loocbooc-dev

# --- Auth ---
SECRET_KEY=dev-secret-change-in-production-32-chars-minimum
JWT_SECRET=dev-secret-change-in-production
API_KEY_PREFIX=lb_live_

# --- Anthropic (optional — OCR degrades gracefully without it) ---
ANTHROPIC_API_KEY=

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Pipeline worker (internal) ---
API_BASE_URL=http://api:8000
PIPELINE_API_KEY=lb_live_testkey_charcoal
