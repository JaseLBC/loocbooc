# ================================================================
# Loocbooc Environment Variables
# ================================================================
# Copy to .env and fill in real values.
# Docker Compose uses these for all services.
# ================================================================

# ── Database ───────────────────────────────────────────────────
# Local: Docker Compose provides this automatically
# Production: Use Supabase connection string
DATABASE_URL=postgresql://loocbooc:loocbooc_dev_password@localhost:5432/loocbooc

# ── Redis ──────────────────────────────────────────────────────
# Local: Docker Compose provides this automatically
# Production: Use Upstash or AWS ElastiCache
REDIS_URL=redis://localhost:6379/0

# ── Supabase (Auth + Realtime) ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ─────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shopify ────────────────────────────────────────────────────
# Get from Shopify Partners Dashboard > Apps > Your App > API credentials
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...
# Required scopes: read_products, write_products, read_orders, write_orders, read_customers

# ── Resend (Email) ─────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@loocbooc.com

# ── S3 / MinIO (File Storage) ──────────────────────────────────
# Local: MinIO provided by Docker Compose
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=loocbooc-dev
S3_REGION=us-east-1
# Production: Use AWS S3 or Cloudflare R2
# S3_ENDPOINT=https://s3.ap-southeast-2.amazonaws.com
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_BUCKET=loocbooc-production

# ── Internal Service Secret ────────────────────────────────────
# Used for service-to-service auth (API <-> Worker)
INTERNAL_SERVICE_SECRET=generate-a-long-random-string-for-production

# ── General ────────────────────────────────────────────────────
NODE_ENV=development
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000

# ── Public (exposed to frontend) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
