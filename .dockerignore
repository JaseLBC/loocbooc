dist
**/dist
.next
**/.next
.turbo
**/.turbo

# Local environment
.env
.env.local
.env.*.local
*.local

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage
**/*.test.ts
**/*.spec.ts
__tests__

# Documentation
docs
*.md
!README.md

# Misc
*.log
*.tgz
.npmrc
