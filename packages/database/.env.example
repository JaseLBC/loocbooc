# Database — Supabase PostgreSQL
# Get these from your Supabase project → Settings → Database

# Pooled connection URL (used by the app server — via PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma migrations — bypasses PgBouncer)
DIRECT_DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"
