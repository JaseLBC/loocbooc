# Loocbooc API Environment Variables
# Copy to .env and fill in your values

# App
APP_NAME=Loocbooc API
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-32-plus-char-random-string

# Database
DATABASE_URL=postgresql+asyncpg://loocbooc:loocbooc@localhost:5432/loocbooc

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/loocbooc-storage
# For S3:
# STORAGE_BACKEND=s3
# STORAGE_BUCKET=loocbooc-garments
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=ap-southeast-2

# Anthropic (required for care label OCR)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
