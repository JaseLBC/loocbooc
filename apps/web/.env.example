# ── Supabase ───────────────────────────────────────────────────────────────────
# Get from Supabase project → Settings → API
# NEXT_PUBLIC_ prefix = exposed to browser
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."  # Safe to expose — RLS protects data

# ── API URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://api.loocbooc.com"  # Public API URL
API_URL="http://api-internal:3001"              # Internal URL for server-to-server (faster)

# ── Stripe ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."  # Safe to expose — frontend only

# ── Node env ───────────────────────────────────────────────────────────────────
NODE_ENV=development
