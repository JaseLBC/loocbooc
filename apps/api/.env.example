# ============================================================
# apps/api — Core Fastify API
# ============================================================
# Copy to .env and fill in values. Never commit .env.

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ------------------------------------------------------------
# Shopify App credentials
# Required for HMAC webhook validation and Admin API calls.
# Obtain from: https://partners.shopify.com → Apps → [your app]
# ------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# The public URL of the Shopify embedded app
# Used when registering webhook callback URLs
SHOPIFY_APP_URL=

# Comma-separated list of required OAuth scopes
SHOPIFY_SCOPES=write_orders,read_products,write_draft_orders

# AES-256-GCM encryption key for storing Shopify access tokens.
# Must be exactly 64 hex characters (= 32 bytes = 256 bits).
# Generate with: openssl rand -hex 32
SHOPIFY_TOKEN_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=

# Supabase direct connection (for migrations)
DIRECT_URL=

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Redis (BullMQ job queues)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Upstash Redis (production): rediss://:<password>@<host>:6380

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Internal service auth
# Shared secret for service-to-service calls (e.g. web → api)
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
INTERNAL_WEBHOOK_SECRET=

# ------------------------------------------------------------
# AWS (S3 + CloudFront + EventBridge)
# ------------------------------------------------------------
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=loocbooc-assets
CLOUDFRONT_DOMAIN=

# EventBridge event bus name
EVENTBRIDGE_BUS_NAME=loocbooc

# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@loocbooc.com
# Email address for critical platform alerts (chargebacks, disputes, errors)
ADMIN_ALERT_EMAIL=admin@loocbooc.com
# Public URL of the web app (used in email CTAs)
WEB_APP_URL=https://loocbooc.com

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
SENTRY_DSN=
